{
  "name": "warden",
  "version": "3.0.1",
  "description": "A gatekeeper for vault that verifies a server should have a vault token",
  "directories": {
    "doc": "docs",
    "bin": "bin"
  },
  "scripts": {
    "start": "node ./bin/server.js",
    "test": "mocha --require ./test/init",
    "cover": "rm -Rf coverage/* && istanbul cover _mocha -- -R spec",
    "lint": "eslint bin/* lib/*.js lib/**/*.js test/*.js",
    "report": "coveralls < ./coverage/lcov.info"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rapid7/warden.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rapid7/warden/issues"
  },
  "homepage": "https://github.com/rapid7/warden#readme",
  "dependencies": {
    "aws-sdk": "~2.1693.0",
    "body-parser": "~2.2.2",
    "express": "~5.2.1",
    "express-winston": "~4.2.0",
    "nconf": "~0.13.0",
    "nock": "~14.0.11",
    "path": "~0.12.7",
    "winston": "~3.19.0",
    "yargs": "~18.0.0"
  },
  "devDependencies": {
    "chai": "~6.2.2",
    "chai-as-promised": "~8.0.2",
    "coveralls": "~3.1.1",
    "eslint": "^10.0.3",
    "eslint-config-rapid7": "^3.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "expect": "~30.3.0",
    "istanbul": "~0.4.5",
    "mocha": "~11.7.5",
    "mocha-lcov-reporter": "~1.3.0",
    "proxyquire": "~2.1.3",
    "should": "~13.2.3",
    "should-sinon": "0.0.6",
    "sinon": "~21.0.3",
    "supertest": "~7.2.2"
  }
}
